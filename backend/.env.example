# ─── OpenClaw Gateway Configuration ─────────────────────────────────────────
# Make sure OpenClaw Gateway is running locally: openclaw gateway --port 18789
# The backend calls the `openclaw agent` CLI command for message parsing
# No API URL needed - uses installed OpenClaw instance
OPENCLAW_PORT=18789

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Download credentials.json from Google Cloud Console and place it in this folder.
# Run: node auth-setup.js   to complete the OAuth flow and create token.json
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./token.json

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ─── Calendar ────────────────────────────────────────────────────────────────
# The calendar ID where events will be created. Use "primary" for the default.
GOOGLE_CALENDAR_ID=primary
