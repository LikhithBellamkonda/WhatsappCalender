# ─── OpenClaw Configuration ───────────────────────────────────────────────
# Make sure OpenClaw is running locally: openclaw serve
# OpenClaw local API endpoint (default: http://localhost:8000/api/v1/chat/completions)
OPENCLAW_API_URL=http://localhost:8000/api/v1/chat/completions

# OpenClaw model to use (default: default)
# Check available models: openclaw models list
OPENCLAW_MODEL=default

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Download credentials.json from Google Cloud Console and place it in this folder.
# Run: node auth-setup.js   to complete the OAuth flow and create token.json
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./token.json

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ─── Calendar ────────────────────────────────────────────────────────────────
# The calendar ID where events will be created. Use "primary" for the default.
GOOGLE_CALENDAR_ID=primary
