# ─── Ollama Configuration ───────────────────────────────────────────────────
# Make sure Ollama is running locally: ollama serve
# Ollama local API endpoint (default: http://localhost:11434)
OLLAMA_API_URL=http://localhost:11434/api/chat

# Ollama model to use. Download with: ollama pull <model>
# Recommended models: mistral, neural-chat, llama2, openchat
# For better performance: mistral or neural-chat
OLLAMA_MODEL=mistral

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Download credentials.json from Google Cloud Console and place it in this folder.
# Run: node auth-setup.js   to complete the OAuth flow and create token.json
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./token.json

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ─── Calendar ────────────────────────────────────────────────────────────────
# The calendar ID where events will be created. Use "primary" for the default.
GOOGLE_CALENDAR_ID=primary
